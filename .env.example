APP_URL=http://localhost
APP_ENV=local
APP_PORT=8081
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:3000

DB_HOST=postgres
DB_PORT=5432
DB_NAME=wishlist
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your-secret-key-min-32-chars-recommended
JWT_EXPIRY_HOURS=168
JWT_ISSUER=wishlist-backend
JWT_AUDIENCE=wishlist-frontend

# OAuth2
OAUTH_PROVIDER=github
OAUTH_CLIENT_ID=your_github_client_id
OAUTH_CLIENT_SECRET=your_github_client_secret
OAUTH_REDIRECT_URL=http://localhost/api/v1/auth/oauth/callback

# S3 / Yandex Object Storage
S3_ENDPOINT=https://storage.yandexcloud.net
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_BUCKET=your-bucket-name
S3_BASE_URL=https://storage.yandexcloud.net/your-bucket-name
S3_REGION=ru-central1

# Email / SMTP - Primary (Yandex)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=your-email@yandex.ru
SMTP_PASSWORD=your_app_password
SMTP_FROM=your-email@yandex.ru

# Email / SMTP - Secondary (Gmail) - optional
SMTP_HOST_2=smtp.gmail.com
SMTP_PORT_2=587
SMTP_USERNAME_2=your-gmail@gmail.com
SMTP_PASSWORD_2=your-gmail-app-password
SMTP_FROM_2=your-gmail@gmail.com

# Email / SMTP - Tertiary (Mail.ru) - optional
SMTP_HOST_3=smtp.mail.ru
SMTP_PORT_3=587
SMTP_USERNAME_3=your-mail@mail.ru
SMTP_PASSWORD_3=your-mail-password
SMTP_FROM_3=your-mail@mail.ru

